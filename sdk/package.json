{
  "name": "ce-plugin-sdk-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "release": "pnpm publish:packages",
    "publish:packages": "pnpm --dir packages/plugin-sdk publish --access public --no-git-checks && pnpm --dir packages/plugin-sandbox publish --access public --no-git-checks && pnpm --dir packages/create-ce-plugin publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@atheory-ai/ce-plugin-sdk": "workspace:*",
    "@atheory-ai/wasm-plugin-toolkit": "^0.0.4",
    "@changesets/cli": "^2.x",
    "typescript": "^5.x",
    "eslint": "^8.x",
    "@typescript-eslint/parser": "^6.x",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "vitest": "^1.x",
    "esbuild": "^0.20.x"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
