{
  "name": "hello-world-plugin",
  "version": "0.1.0",
  "description": "Minimal CE plugin example",
  "type": "module",
  "scripts": {
    "build": "ce-plugin-build --plugin . --output dist/hello-world.wasm",
    "build:stream": "wasm-toolkit-build --plugin . --config ../../wasm-toolkit.config.mjs --output dist/hello-world.dev.wasm",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atheory-ai/ce-plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@atheory-ai/wasm-plugin-toolkit": "^0.0.4",
    "typescript": "*"
  }
}
