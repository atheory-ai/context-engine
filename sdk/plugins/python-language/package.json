{
  "name": "python-language-plugin",
  "version": "1.0.0",
  "description": "Default Python language plugin — functions, classes, methods, imports, decorators",
  "type": "module",
  "scripts": {
    "build":     "ce-plugin-build --plugin . --output dist/python.wasm",
    "build:stream": "wasm-toolkit-build --plugin . --config ../../wasm-toolkit.config.mjs --output dist/python.dev.wasm",
    "build:dev": "tsc --watch",
    "test":      "vitest run --passWithNoTests",
    "validate":  "ce plugin validate dist/python.wasm",
    "clean":     "rm -rf dist"
  },
  "dependencies": {
    "@atheory-ai/ce-plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@atheory-ai/wasm-plugin-toolkit": "^0.0.4",
    "@types/node": "^20.x",
    "typescript": "*",
    "vitest":     "*"
  }
}
