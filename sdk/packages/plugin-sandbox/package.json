{
  "name": "@atheory-ai/ce-plugin-sandbox",
  "version": "0.1.1",
  "description": "Local sandbox CLI for validating Context Engine plugins.",
  "type": "module",
  "bin": {
    "ce-sandbox": "./dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs && chmod +x dist/index.js",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "lint": "eslint src tests build.mjs --ext .ts,.js,.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atheory-ai/ce-plugin-sdk": "workspace:^",
    "chalk": "^5.x"
  },
  "devDependencies": {
    "typescript": "*",
    "esbuild": "*",
    "vitest": "*",
    "@types/node": "^20.x"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/atheory-ai/context-engine/tree/main/sdk/packages/plugin-sandbox#readme",
  "bugs": {
    "url": "https://github.com/atheory-ai/context-engine/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atheory-ai/context-engine.git",
    "directory": "sdk/packages/plugin-sandbox"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": ["context-engine", "plugin", "wasm", "validation", "cli"]
}
