  {
    "kind": "FunctionIntent",
    "name": "Load",
    "language": "go",
    "visibility": "public",
    "inputs": [
      {
        "name": "id",
        "type": "string"
      }
    ],
    "returns": {
      "type": "([]byte, error)",
      "explicit": true
    },
    "behavior": [
      {
        "when": "id == \"\"",
        "then": "return nil, errors.New(\"empty id\")",
        "whenExpr": {
          "op": "==",
          "args": [
            {
              "op": "path",
              "text": "id"
            },
            {
              "op": "lit",
              "text": "\"\""
            }
          ]
        }
      },
      {
        "when": "err != nil",
        "then": "return nil, err",
        "whenExpr": {
          "op": "!=",
          "args": [
            {
              "op": "path",
              "text": "err"
            },
            {
              "op": "lit",
              "text": "nil"
            }
          ]
        }
      },
      {
        "when": "len(data) == 0",
        "then": "return nil, ErrClosed"
      }
    ],
    "sideEffects": [
      "errors.New"
    ],
    "failureModes": [
      "ErrClosed",
      "empty id"
    ],
    "constraints": []
  },
  {
    "kind": "FunctionIntent",
    "name": "Save",
    "language": "go",
