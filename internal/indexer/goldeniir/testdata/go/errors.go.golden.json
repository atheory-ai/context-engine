        "type": "[]byte"
      }
    ],
    "returns": {
      "type": "error",
      "explicit": true
    },
    "behavior": [
      {
        "when": "data == nil",
        "then": "panic(\"nil data\")",
        "whenExpr": {
          "op": "==",
          "args": [
            {
              "op": "path",
              "text": "data"
            },
            {
              "op": "lit",
              "text": "nil"
            }
          ]
        }
      },
      {
        "when": "id == \"\"",
        "then": "return fmt.Errorf(\"save %q: %w\", id, ErrClosed)",
        "whenExpr": {
          "op": "==",
          "args": [
            {
              "op": "path",
              "text": "id"
            },
            {
              "op": "lit",
              "text": "\"\""
            }
          ]
        }
      }
    ],
    "sideEffects": [
      "fmt.Errorf"
    ],
    "failureModes": [
      "nil data",
      "save %q: %w"
    ],
    "constraints": []
  },
