    "behavior": [
      {
        "when": "amount.cents \u003c campaign.minimumDonation.cents",
        "then": "throw new Error(\"below_minimum\")",
        "whenExpr": {
          "op": "\u003c",
          "args": [
            {
              "op": "path",
              "text": "amount.cents"
            },
            {
              "op": "path",
              "text": "campaign.minimumDonation.cents"
            }
          ]
        }
      }
    ],
    "sideEffects": [],
    "failureModes": [
